<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" package="com.osamnsa.xmrminer">

    <!-- Needed to reach the mining pool you configure in the app, and to
         load banner ads. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Held only while the foreground mining service below is running,
         which only happens after the user taps Start. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="@string/app_title"
        android:icon="@drawable/ic_launcher"
        android:roundIcon="@drawable/ic_launcher"
        android:theme="@style/Theme.AppCompat.NoActionBar"
        android:allowBackup="false">

        <!-- Required by the Google Mobile Ads SDK; the AdView in
             activity_main.xml won't load without this. -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-8281272452414129~2053710122" />

        <activity
            android:name=".SplashActivity"
            android:theme="@style/Theme.Architect.Splash"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".MainActivity" android:exported="false" />

        <service
            android:name=".MiningService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="User-initiated on-device Monero (XMR) mining. Runs only while the user has it started; shows a persistent notification with a Stop action the entire time." />
        </service>
    </application>
</manifest>
